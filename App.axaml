<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DeployPaladin.App"
             RequestedThemeVariant="Light">
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://DeployPaladin/Styles/AquaStyle.axaml"/>
        <StyleInclude Source="avares://DeployPaladin/Styles/Windows11Style.axaml"/>
    </Application.Styles>
</Application>
